# frontend/.env.local
# Person A will give you these URLs after deploying the Lambdas.
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit real URLs.

REACT_APP_UPLOAD_URL=https://YOUR_UPLOAD_LAMBDA_URL
REACT_APP_QUIZ_URL=https://YOUR_QUIZ_LAMBDA_URL
REACT_APP_MAIN_URL=https://YOUR_MAIN_LAMBDA_URL
